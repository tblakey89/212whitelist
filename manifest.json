{
  "manifest_version": 3,
  "name": "WhitelistWeb",
  "version": "1.0.0",
  "description": "Parental control: locks every website behind a password until a grown-up allows it for this browsing session.",
  "permissions": ["webNavigation", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhitelistWeb"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["locked.html", "locked.css", "locked.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
